{
  "manifest_version": 3,
  "name": "SafeTabGuard V2",
  "version": "2.0.0",
  "description": "Enterprise-grade privacy hardening, WebRTC protection, and AI-driven threat detection.",

  "permissions": [
    "tabs",
    "scripting",
    "storage",
    "alarms",
    "activeTab",
    "webNavigation",
    "privacy",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "declarativeNetRequestFeedback"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background/background.js"
  },

  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "background/rules.json"
      }
    ]
  },

  "web_accessible_resources": [
    {
      "resources": ["content/canvas_poison.js"],
      "matches": ["<all_urls>"]
    }
  ],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/canvas_noise.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content/canvas_poison.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN" 
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content/scanner.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "SafeTabGuard UI",
    "default_icon": {
      "16": "icons/STG_icon.png",
      "48": "icons/STG_icon.png",
      "128": "icons/STG_icon.png"
    }
  },

  "icons": {
    "16": "icons/STG_icon.png",
    "48": "icons/STG_icon.png",
    "128": "icons/STG_icon.png"
  }
}